# Somnia Testnet
SOMNIA_TESTNET_RPC=https://dream-rpc.somnia.network
SOMNIA_CHAIN_ID=50312

# Public Somnia Agents constants used by Steward.
SOMNIA_AGENTS=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776
SOMNIA_AGENT_REGISTRY=0x08D1Fc808f1983d2Ea7B63a28ECD4d8C885Cd02A
SOMNIA_RECEIPT_BASE=https://receipts.testnet.agents.somnia.host/agent-receipts
LLM_AGENT_ID=12847293847561029384
PARSE_WEBSITE_AGENT_ID=12875401142070969085

# Required only for live deployments or new vote requests.
# Never commit a funded private key.
PRIVATE_KEY=

# Optional live deployment targets for scripts.
HELLO_CALLBACK=
MINI_GOVERNOR=0xa3773Ff7B2008bAb2E553E13e1E0ADE08a15f389
STEWARD=0x6932C7827E7BFd9f0015Ed93fA120379E0d20541
STEWARD_URL_PIPELINE=

# Optional web build flag. Set this before deploying web/ after
# StewardUrlPipeline is live to expose the browser URL-vote console.
VITE_STEWARD_URL_PIPELINE=

# Optional request tuning.
REQUEST_VALUE=240000000000000000
VOTING_PERIOD=604800
DELEGATION_DURATION=2592000
PROPOSAL_TEXT=Allocate 500K USDC to a Q3 community grants program.
CRITERIA_TEXT=Vote YES for community grants under 1M, NO for team token unlocks, ABSTAIN if unclear.
PROPOSAL_ID=1
PROPOSAL_URL=https://example.com/governance/proposal
RESOLVE_URL=false

# Optional only after a live StewardUrlPipeline run.
# Used by scripts/verify-url-pipeline-trail.mjs to verify the full
# Parse Website -> LLM Inference -> MiniGovernor vote transaction trail.
URL_PIPELINE_JOB_ID=
URL_PIPELINE_PROPOSAL_ID=
URL_PIPELINE_EXPECTED_SUPPORT=
URL_PIPELINE_EXPECTED_REASON=
URL_PIPELINE_CRITERIA=
URL_PIPELINE_PROPOSAL_URL=
URL_PIPELINE_SUMMARY=
URL_PIPELINE_START_TX=
URL_PIPELINE_PARSE_CALLBACK_TX=
URL_PIPELINE_VOTE_CALLBACK_TX=

# Optional log collection helpers for scripts/collect-url-pipeline-proof-env.mjs.
# Set FROM_BLOCK to the StewardUrlPipeline deploy block or seeding block when known.
URL_PIPELINE_FROM_BLOCK=
URL_PIPELINE_TO_BLOCK=
URL_PIPELINE_SCAN_BLOCKS=300000
URL_PIPELINE_LOG_CHUNK=50000
URL_PIPELINE_DEPOSIT_BUFFER=0
URL_PIPELINE_EXPECT_CASES=YES,NO,ABSTAIN
URL_PIPELINE_POLL_SECONDS=900
URL_PIPELINE_POLL_INTERVAL=20
URL_PIPELINE_SKIP_SEED=false
URL_PIPELINE_BLOCK_LOOKBACK=5

# Optional batch verifier mode after running script/SeedUrlPipelineProofs.s.sol.
# The EXPECTED_SUPPORT and EXPECTED_REASON values default from YES/NO/ABSTAIN,
# but can be set explicitly if a proof case is named differently.
URL_PIPELINE_CASES=
URL_PIPELINE_YES_JOB_ID=
URL_PIPELINE_YES_PROPOSAL_ID=
URL_PIPELINE_YES_PROPOSAL_URL=https://steward-ashy.vercel.app/proposals/community-grants.html
URL_PIPELINE_YES_SUMMARY=
URL_PIPELINE_YES_PROPOSAL_TX=
URL_PIPELINE_YES_START_TX=
URL_PIPELINE_YES_PARSE_CALLBACK_TX=
URL_PIPELINE_YES_VOTE_CALLBACK_TX=
URL_PIPELINE_NO_JOB_ID=
URL_PIPELINE_NO_PROPOSAL_ID=
URL_PIPELINE_NO_PROPOSAL_URL=https://steward-ashy.vercel.app/proposals/team-token-unlock.html
URL_PIPELINE_NO_SUMMARY=
URL_PIPELINE_NO_PROPOSAL_TX=
URL_PIPELINE_NO_START_TX=
URL_PIPELINE_NO_PARSE_CALLBACK_TX=
URL_PIPELINE_NO_VOTE_CALLBACK_TX=
